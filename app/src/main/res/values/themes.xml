<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MFD" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_teal</item>
        <item name="colorPrimaryDark">@color/bg_dark</item>
        <item name="colorAccent">@color/accent_blue</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:windowAnimationStyle">@style/WindowFade</item>
    </style>

    <style name="Theme.MFD.Light" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/accent_teal</item>
        <item name="colorPrimaryDark">@color/bg_light</item>
        <item name="colorAccent">@color/accent_blue</item>
        <item name="android:windowBackground">@color/bg_light</item>
        <item name="android:statusBarColor">@color/bg_light</item>
        <item name="android:navigationBarColor">@color/bg_light</item>
        <item name="android:textColor">@color/text_primary_light</item>
    </style>

    <style name="WindowFade">
        <item name="android:activityOpenEnterAnimation">@android:anim/fade_in</item>
        <item name="android:activityOpenExitAnimation">@android:anim/fade_out</item>
        <item name="android:activityCloseEnterAnimation">@android:anim/fade_in</item>
        <item name="android:activityCloseExitAnimation">@android:anim/fade_out</item>
    </style>

    <style name="MFDButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/accent_teal</item>
        <item name="android:textColor">@color/bg_dark</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="MFDCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
    </style>
</resources>
